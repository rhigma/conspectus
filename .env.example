# ── Claude API ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ─────────────────────────────────────────────────
PORT=3000
# Setze ein langes zufälliges Passwort: openssl rand -hex 32
API_SECRET=AENDERN_openssl_rand_hex_32

# ── Modell-Routing ──────────────────────────────────────────
# Für einfache Abfragen (Übersicht, Suche)
MODEL_FAST=claude-haiku-4-5-20251001
# Für komplexe Aufgaben und Bildanalyse (Handschrift)
MODEL_SMART=claude-sonnet-4-6

# ── Sync-Intervall (Minuten) ────────────────────────────────
SYNC_INTERVAL_MINUTES=5
